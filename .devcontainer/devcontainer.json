{
    "image": "sandbox:latest",
    "runArgs": ["--add-host=host.docker.internal:host-gateway"],
    "remoteEnv": {
        "OLLAMA_HOST": "http://localhost:11434",
        "OLLAMA_API_KEY": "${localEnv:OLLAMA_API_KEY}"
    },
    "workspaceFolder": "/workspace/kantan-gwadloup",
    "remoteUser": "ubuntu",
    "name": "Flutter CLI Development with Firebase (Headless)",
    "mounts": [
        "source=/home/loic/.gitconfig,target=/home/ubuntu/.gitconfig,type=bind,consistency=cached",
        "source=${localWorkspaceFolder}/,target=/workspace/${localWorkspaceFolderBasename}/,type=bind,consistency=cached"
    ],
    "postCreateCommand": "bash .devcontainer/setup.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "Dart-Code.flutter",
                "Dart-Code.dart-code",
                "ms-vscode.vscode-nodejs-extension-pack",
                "Firebase.firebase-snippets"
            ]
        }
    },
    "forwardPorts": [5037]
}
